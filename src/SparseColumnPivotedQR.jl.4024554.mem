        0             end
        -             continue
        -         end
        - 
        0         x1 = x[vrows[1]]
        -         sgn = if T <: Real
        0             x1 >= 0 ? one(T) : -one(T)
        -         else
        -             x1 == 0 ? one(T) : x1 / abs(x1)
        -         end
        0         nrm = sqrt(nrm2)
        0         alpha = -sgn * nrm
        0         v1 = x1 - alpha
        -         # vnorm2 = |v1|^2 + sum_{j>=2} |x[j]|^2 = |v1|^2 + (nrm2 - |x1|^2)
