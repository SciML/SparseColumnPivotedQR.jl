        0         if vnz_total + vlen > length(V.rowval)
        0             _grow_csc!(V, vnz_total + vlen)
        -         end
        0         vnz_total += 1
        0         V.rowval[vnz_total] = k
        0         V.nzval[vnz_total] = v1
        0         for q in 2:vlen
        0             xv = x[vrows[q]]
        0             if xv != zero(T)
        0                 vnz_total += 1
        0                 V.rowval[vnz_total] = vrows[q]
        0                 V.nzval[vnz_total] = xv
        -             end
        0         end
        0         V.colptr[k + 1] = vnz_total + 1
        - 
        0         beta[k] = beta_k
        0         rnk += 1
        - 
        -         # Clear x at v-pattern rows.
        0         for q in 1:vlen
        0             x[vrows[q]] = zero(T)
        0         end
        0     end
        - 
        -     # Trim V/R to actual sizes.
        0     resize!(V.rowval, vnz_total); resize!(V.nzval, vnz_total)
        0     resize!(R.rowval, rnz_total); resize!(R.nzval, rnz_total)
        - 
        0     return CSRQRFactorization{T, RT}(sym.m, sym.n,
        -         V.colptr, V.rowval, V.nzval,
        -         R.colptr, R.rowval, R.nzval,
        -         beta, rnk, tol_use, sym)
