        - 
        0         if vnorm2 <= zero(RT)
        -             # Pathological: H = I. Treat as rank-deficient pivot.
        0             rnz_total += 1
        0             R.rowval[rnz_total] = k
        0             R.nzval[rnz_total] = T(alpha)
        0             R.colptr[k + 1] = rnz_total + 1
        0             V.colptr[k + 1] = vnz_total + 1
        0             beta[k] = zero(RT)
        0             for q in 1:vlen
        0                 x[vrows[q]] = zero(T)
        0             end
        0             if abs(alpha) > tol_use
        0                 rnk += 1
        -             end
        0             continue
        -         end
        - 
        0         beta_k = RT(2) / vnorm2
        - 
        -         # Emit R[k, k] = alpha.
        0         rnz_total += 1
        0         R.rowval[rnz_total] = k
        0         R.nzval[rnz_total] = T(alpha)
        0         R.colptr[k + 1] = rnz_total + 1
