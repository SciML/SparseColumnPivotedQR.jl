        0                 ri = V.rowval[vp]
        0                 if rowmark[ri] != k
        0                     rowmark[ri] = k
        0                     vlen += 1
        0                     vrows[vlen] = ri
        -                 end
        0             end
        0             bk = beta[p_idx]
        0             if vc2 >= vc1 && bk != 0
        -                 tau = zero(T)
        0                 for vp in vc1:vc2
        0                     tau += conj(V.nzval[vp]) * x[V.rowval[vp]]
        0                 end
        0                 if tau != 0
        0                     tau_b = T(bk) * tau
        0                     for vp in vc1:vc2
