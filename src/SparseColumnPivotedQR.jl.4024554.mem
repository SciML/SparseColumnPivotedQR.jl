        0             R.rowval[rnz_total] = k
        0             R.nzval[rnz_total] = zero(T)
        0             R.colptr[k + 1] = rnz_total + 1
        0             V.colptr[k + 1] = vnz_total + 1
        0             beta[k] = zero(RT)
