        -                 len = 0
        -                 jj = lm
        0                 while jj != 0 && w[jj] != k && jj < k
        0                     s[len + 1] = jj
        0                     len += 1
        0                     w[jj] = k
        0                     jj = parent[jj]
        -                 end
        -                 # Transfer s[1..len] (deepest-first walk order) into
