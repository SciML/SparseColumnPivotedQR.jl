        - function _capture_pattern(A::SparseMatrixCSR{Bi}) where {Bi}
        -     off = getoffset(A)
     3328     rowptr = Vector{Int}(undef, length(A.rowptr))
        0     @inbounds for i in eachindex(A.rowptr)
