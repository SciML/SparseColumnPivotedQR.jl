        - # Upper-bound estimate of nnz(V) and nnz(R), used to pre-size CSC buffers.
        - # Tightens iteratively if exceeded by `_grow_csc!`.
        - function _vnz_rnz_estimate(colptr::Vector{Int}, rowval::Vector{Int},
        -                             parent::Vector{Int},
        -                             leftmost_orig::Vector{Int},
        -                             m::Int, n::Int)
