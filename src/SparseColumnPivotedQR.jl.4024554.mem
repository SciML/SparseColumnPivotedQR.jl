        - # Numeric loop. Returns a CSRQRFactorization.
        - function _csc_qr_numeric(colptr::Vector{Int}, rowval::Vector{Int},
        -                          nzval::Vector{T}, sym::CSRQRSymbolic,
        -                          tol_use::RT, tol2::RT) where {T, RT}
        0     m, n, m2 = sym.m, sym.n, sym.m2
        0     parent = sym.parent
        0     leftmost = sym.leftmost
        - 
   872320     V = _alloc_csc(T, m2, n, sym.vnz)
   372800     R = _alloc_csc(T, n, n, sym.rnz)
     3328     beta = zeros(RT, n)
        - 
        -     # Workspaces.
     4624     x = zeros(T, m2)
     3328     s = zeros(Int, n)
     3328     w = zeros(Int, n)       # ereach marker by column (mark = k each step)
     4624     rowmark = zeros(Int, m2)  # V-pattern marker by row (mark = k each step)
     4624     vrows = zeros(Int, m2)
