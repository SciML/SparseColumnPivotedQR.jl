        0             R.rowval[rnz_total] = p_idx
        0             R.nzval[rnz_total] = x[p_idx]
        0             x[p_idx] = zero(T)
        0         end
        - 
        -         # Ensure row k is in vrows.
        0         if rowmark[k] != k
        0             rowmark[k] = k
